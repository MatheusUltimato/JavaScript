Exemplos do function
(Para conseguir colocar variáveis dentro da função, crie uma variável PRIMEIRO antes da propria função e depois chame ela na própria função para funcionar)

// Criar um código aleatório de 6 digitos
var numeros=(Math.floor(Math.random() *999999)); /*Escolhe aleatóriamente entre o número escolhido(999999)*/

function senha(codigo){ /*Cria uma função chamada senha, mas com a ação de uma outra escolhida(codigo)*/
    console.log(`O código é aleatório: ${codigo}`)
}
senha(numeros); 
/*Executa a váriavel (numeros) dentro da ação (codigo) na função (senha) */


//Entrega onde são entregadas cargas aleatórias
let carga = Math.floor(Math.random() *20)
let caixas = carga*5
let produtos = caixas*2

function Entrega(){
    console.log(`Foram entregadas: ${carga} cargas, ${caixas} caixas e ${produtos} produtos`)
}
if (carga === 0){ /*uma condicao para quando nao houver cargas na entrega*/
    console.log("Não foi entregado")
}
else {
    Entrega();
}


//Calculos aleatórios

let  adiçao=Math.floor(Math.random() *70)
let  negativo=Math.floor(Math.random() *-40)
let  divisor=Math.floor(Math.random() *10)
let  multiplicador=Math.floor(Math.random() *5)
const calculum= Math.floor(adiçao+negativo/divisor*multiplicador)

if (multiplicador === 0){
    console.log(`O calculo não é complexo porque o multiplicador é: ${multiplicador} \n`)
}
else if (divisor === 0){
    console.log(`O calculo não consegue ser feito porque o divisor é: ${divisor} \n`)
}
function calculo(){
    console.log(`O resultado dos calculos é de: ${calculum}
     +${adiçao}${negativo}/${divisor}*${multiplicador}`)
}
calculo();


//O return funciona como uma execução para a ação escolhida, como se fosse uma calculadora, mas ela não executa porque o (=) não foi executado

//Primeiro Exemplo: Em um livro, para cada pagina tem 5 capitulos

function livro(paginas,capitulos){
  const livro = paginas * capitulos /*Cria um uma váriavel com uma ação*/
  return livro /*Retorna a ação da váriavel para ela ser executada(Chama a váriavel)*/

}

//Exemplo:
console.log(livro(200 /*Número de paginas*/,5 /*Número de capitulos por pagina*/))
/*Resposta= 1000 */

//Exemplo se forem paginas aleatórias:
console.log(livro(Math.floor(Math.random()*350 /*Tem no máximo 350*/), 5 /*Número de capítulos para cada página*/))
/*Resposta: De 1-350 paginas * 5 capitulos */


//Segundo Exemplo do Return

//1 ou 2 mensagens precisam ser enviadas

function ativacaodeMensagens(mensagem1,mensagem2){
    mensagem = mensagem1 + mensagem2
    return mensagem
}
//Exemplo se for colocado 1 mensagem:
console.log(ativacaodeMensagens("Agora são 8 horas da manhã ")/*A segunda mensagem não foi definida por isso é colocado undefined*/)

//Exemplo se for 2 mensagens:
console.log(ativacaodeMensagens("Numa Montanha "/*Colocando a primeira funcão na (mensagem1)*/,"existe um Horizonte" /*Colocando a segunda funcão na (mensagem2)*/))

// Function simplificado e criado com seta(Arrows)
const Grama = (Terreno) =>{ /* Na váriavel é criado outra váriavel (Terreno) e junto a => que faz a função dela */
    if (Terreno === 'Cortado')
    return ("Não precisa a grama ser cortada")
    else if (Terreno === "Crescido")
    return ("A grama precisa ser cortada")
    else
    return ("Esse terreno não existe")
}
console.log(Grama('Cortado'))


